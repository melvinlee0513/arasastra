# Aras A+ — public frontend environment variables.
# All VITE_* values are inlined into the browser bundle at build time and
# are considered PUBLIC. Never put the Supabase service_role key here.

# Supabase (Lovable Cloud) — copy from Lovable project .env
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase-anon-key>"
VITE_SUPABASE_PROJECT_ID="<supabase-project-ref>"

# Optional runtime hints (not required today; reserved for future use)
# VITE_APP_ENV="production"
# VITE_HQ_ROOT_DOMAIN="arasaplus.info"
# VITE_TENANT_DEBUG="false"
